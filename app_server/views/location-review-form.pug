extends layout

block content
    .row.banner 
        .col-12 
            h1 Review Location "#{location.name}"
    .row 
        .col-12.col-lg-9
            form(action=`/location/${location._id}/review/new` method="POST")
                .form-group 
                    label(for="name") Name 
                    input.form-control(type="text" id="name" name="name")
                .form-group 
                    label(for="rating") Rating 
                    select.form-control(id="rating" name="rating")
                        option 0
                        option 1
                        option 2
                        option 3
                        option 4
                        option 5
                .form-group 
                    label(for="review")
                    textarea.form-control(id="review" placeholder="Ejemplo, no me gusta" name="review")
                button.btn.btn-primary(type="submit") Submit Review
                    