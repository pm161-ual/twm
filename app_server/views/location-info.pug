extends layout

include _includes/sharedHTMLfunctions

block content
    .row.banner 
        .col-12 
            h1 #{location.name} 
    .row 
        .col-12.col-lg-9
            .row
                .col-12.col-md-6
                    p
                        +outputRating(location.rating)
                    p #{location.address}
                    .card.card-primary.mb-3
                        .card-body 
                            h2.card-title Opening hours
                            if location.openingTimes && location.openingTimes.length
                                each openingTimes in location.openingTimes
                                    p.card-text
                                        strong #{openingTimes.days}:
                                        if openingTimes.closed
                                            |  closed
                                        else
                                            |  #{openingTimes.opening} - #{openingTimes.closing}
                            else
                                p.card-text
                                    strong Monday - Friday:
                                    |  7:00am - 7:00pm
                                p.card-text
                                    strong Saturday:
                                    |  8:00am - 5:00pm
                                p.card-text
                                    strong Sunday:
                                    |  closed
                    .card.card-primary.mb-3
                        .card-body 
                            h2.card-title Facilities 
                            each facility in location.facilities
                                span.badge.badge-warning #{facility}
                .col-12.col-md-6 
                    .card.card-primary.mb-3 
                        .card-body  
                            h2.card-title Location Map
                            iframe(
                                src="https://maps.google.com/maps?q=125%20High%20Street%2C%20Reading%2C%20RG6%201PS&z=16&output=embed"
                                width="100%"
                                height="250"
                                style="border:0;"
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade")
                            p.card-text.mt-2
                                a(href="https://www.google.com/maps?q=125%20High%20Street%2C%20Reading%2C%20RG6%201PS" target="_blank" rel="noopener noreferrer") Open in Google Maps
            .row 
                .col-12
                        .card.card-primary.mb-3 
                            .card-body
                                h2.card-title Customer reviews
                                    a.btn.btn-secondary.float-right(href=`/location/${location._id}/review/new`) Add Review
                                each review in location.reviews
                                    .card-text
                                        +outputRating(review.rating)
                                        |  
                                        span #{review.author} 
                                        span.date #{review.date}
                                        .float-right
                                            a.btn.btn-link.btn-sm(href=`/location/${location._id}/review/${review._id}/edit`) Edit
                                            form(action=`/location/${location._id}/review/${review._id}/delete` method="POST" style="display:inline;")
                                                button.btn.btn-link.btn-sm(type="submit") Delete
                                        
                                    p.card-text.mt-2 #{review.reviewText}
        .col-12.col-lg-3 
            p #{location.name} is on Loc8r because it has accessible wifi and space to sit down with your laptop and get some work done.
            p If you've been and you like it or if you don't, please leave a review to help other people just like you.
                       